# === Telegram ===
TELEGRAM_BOT_TOKEN=123456789:AAExampleBotTokenHere
# ID channel Telegram tempat kamu posting signal. Bisa berupa @username_channel
# atau numeric id (contoh: -1001234567890). Bot HARUS jadi admin di channel ini.
TELEGRAM_CHANNEL_ID=@your_channel_username
# User_id Telegram (bukan username!) yang boleh pakai /cancel, /close,
# /rekap_harian, /rekap_bulanan. Pisahkan dengan koma kalau lebih dari satu.
# Cara dapat user_id: chat ke @userinfobot di Telegram.
# WAJIB diisi, kalau kosong semua command sensitif ini akan ditolak.
TELEGRAM_ADMIN_IDS=123456789

# === Supabase ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# === Trading defaults ===
# TP dihasilkan otomatis sebagai BEBERAPA level: TP1=RR1:1, TP2=RR1:2, dst
# sampai RR ini. Contoh: 3 -> TP1(RR1), TP2(RR2), TP3(RR3)
DEFAULT_RR_MAX=3

# Interval polling harga ke MEXC (detik)
POLL_INTERVAL_SECONDS=10

# Default quote currency kalau pair tidak menyertakan pasangan (mis. "$NOM" -> "NOMUSDT")
DEFAULT_QUOTE=USDT

# === Recap schedule (waktu lokal, 24h format) ===
TIMEZONE=Asia/Jakarta
DAILY_RECAP_HOUR=23
DAILY_RECAP_MINUTE=59
# Rekap bulanan dikirim tanggal 1 tiap bulan jam berapa (untuk bulan sebelumnya)
MONTHLY_RECAP_DAY=1
MONTHLY_RECAP_HOUR=8
MONTHLY_RECAP_MINUTE=0
